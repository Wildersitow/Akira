         </children>
      </Pane>
      <Pane layoutX="0.0" layoutY="90.0" prefHeight="1.0" prefWidth="1280.0" style="-fx-background-color: #2e2e2e;" />

      <Pane fx:id="pane_producto11" layoutX="40.0" layoutY="110.0" prefHeight="290.0" prefWidth="1200.0" styleClass="panel-hero">
         <children>

            <!-- Texto izquierdo -->
            <Label layoutX="32.0" layoutY="60.0" prefWidth="520.0" styleClass="label-hero-titulo" text="¡Bienvenido a Akira!" />

            <Label layoutX="32.0" layoutY="120.0" prefWidth="480.0" styleClass="label-hero-subtitulo" text="Encuentra tu futuro vehículo eléctrico" />

            <Label layoutX="32.0" layoutY="165.0" prefHeight="60.0" prefWidth="480.0" styleClass="label-hero-descripcion" text="Explora nuestra flota de vehículos disponibles para compra y alquiler. Tecnología de punta al alcance de tu mano." wrapText="true" />
            <Button layoutX="32.0" layoutY="235.0" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" styleClass="boton-cta" text="Ver catálogo →" />

            <ImageView fx:id="imagen_vehiculo_hero" fitHeight="242.0" fitWidth="560.0" layoutX="610.0" layoutY="24.0" pickOnBounds="true" preserveRatio="true" />

         </children>
      </Pane>
      <Pane layoutX="40.0" layoutY="418.0" prefHeight="40.0" prefWidth="1200.0" styleClass="seccion-header-plano">
         <children>
            <Label layoutX="0.0" layoutY="8.0" styleClass="label-seccion-recomendados" text="VEHÍCULOS RECOMENDADOS" />
