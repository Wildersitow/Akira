         </children>
      </Pane>
      <Pane fx:id="pane_producto3" layoutX="864.0" layoutY="465.0" prefHeight="215.0" prefWidth="375.0" styleClass="card-vehiculo">
         <children>
            <ImageView fx:id="imagen_rec3" fitHeight="120.0" fitWidth="355.0" layoutX="10.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true" />

            <Label fx:id="label_rec3" layoutX="14.0" layoutY="138.0" prefWidth="250.0" styleClass="label-card-titulo" text="Recomendado 3" />

            <Button fx:id="boton_ver3" layoutX="200.0" layoutY="170.0" mnemonicParsing="false" prefHeight="32.0" prefWidth="160.0" styleClass="boton-ver-info" text="Ver Información" />
         </children>
      </Pane>

   </children>
</AnchorPane>
