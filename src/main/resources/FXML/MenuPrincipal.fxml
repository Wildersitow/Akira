            <ImageView fx:id="imagen_rec2" fitHeight="120.0" fitWidth="355.0" layoutX="10.0" layoutY="10.0" pickOnBounds="true" preserveRatio="true" />

            <Label fx:id="label_rec2" layoutX="14.0" layoutY="138.0" prefWidth="250.0" styleClass="label-card-titulo" text="Recomendado 2" />

