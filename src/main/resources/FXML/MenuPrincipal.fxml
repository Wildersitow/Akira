<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" styleClass="root" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.ControladorMenuInicio">
   <children>
      <Pane layoutX="0.0" layoutY="0.0" prefHeight="90.0" prefWidth="1280.0" styleClass="navbar">
         <children>
            <ImageView fitHeight="110.0" fitWidth="170.0" layoutX="20.0" layoutY="-10.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../Imagenes/LogoFondoNegro.png" />
               </image>
            </ImageView>
            <Button fx:id="boton_inicio" layoutX="280.0" layoutY="22.0" mnemonicParsing="false" prefHeight="44.0" prefWidth="120.0" styleClass="boton-nav" text="INICIO" />

            <Button fx:id="boton_alquilar" layoutX="420.0" layoutY="22.0" mnemonicParsing="false" prefHeight="44.0" prefWidth="120.0" styleClass="boton-nav" text="ALQUILAR" />

            <Button fx:id="boton_comprar" layoutX="560.0" layoutY="22.0" mnemonicParsing="false" prefHeight="44.0" prefWidth="120.0" styleClass="boton-nav" text="COMPRAR" />

            <Button fx:id="boton_flota" layoutX="700.0" layoutY="22.0" mnemonicParsing="false" prefHeight="44.0" prefWidth="120.0" styleClass="boton-nav" text="FLOTA" />

            <Button fx:id="boton_asistente" layoutX="840.0" layoutY="22.0" mnemonicParsing="false" prefHeight="44.0" prefWidth="120.0" styleClass="boton-nav" text="ASISTENTE" />
