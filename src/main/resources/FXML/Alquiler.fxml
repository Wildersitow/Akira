<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            style="-fx-background-color: #0A0A0A;"
            stylesheets="@../css/stylesCompras.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="view.ControladorMenuAlquiler">

    <HBox fx:id="navbar"
          prefWidth="1280.0" prefHeight="72.0"
          alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #111111; -fx-border-color: #1e1e1e; -fx-border-width: 0 0 1 0;"
          AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <HBox prefWidth="220" prefHeight="72" alignment="CENTER_LEFT">
            <padding><Insets left="24"/></padding>
            <ImageView fitHeight="48" fitWidth="160" preserveRatio="true" pickOnBounds="true">
                <image><Image url="@../Imagenes/logoprovisional.png"/></image>
            </ImageView>
        </HBox>

        <HBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS">
            <Button text="INICIO"      onAction="#cambiarInicio"    styleClass="boton-nav"/>
            <Button text="COMPRAR"     onAction="#cambiarCompras"   styleClass="boton-nav"/>
            <Button text="ALQUILAR"    onAction="#cambiarAlquiler"  styleClass="boton-nav"/>
            <Button text="CONTRATOS"                                styleClass="boton-nav"/>
            <Button text="FLOTA"       onAction="#cambiarFlota"     styleClass="boton-nav"/>
            <Button text="ASISTENTE"   onAction="#cambiarAsistente" styleClass="boton-nav"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <padding><Insets right="20"/></padding>
            <Button fx:id="btnReservas" text="📋  Reservas (0)"
                    onAction="#abrirReservas"
                    styleClass="btn-carrito"/>
            <Button text="CERRAR SESIÓN"
                    styleClass="btn-cerrar"/>
        </HBox>
    </HBox>

    <HBox prefWidth="1280" prefHeight="64" alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: linear-gradient(to right, #9B0F1F, #6b0000);"
          AnchorPane.topAnchor="72" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <padding><Insets left="32"/></padding>
        <Label text="🔑" style="-fx-font-size:22px;"/>
        <VBox spacing="1">
            <Label text="ALQUILA TU VEHÍCULO ELÉCTRICO"
                   style="-fx-text-fill:white; -fx-font-size:18px; -fx-font-weight:bold; -fx-font-family:'Impact Regular';"/>
            <Label text="Elige el vehículo, el período y reserva al instante — disponible en toda Colombia"
                   style="-fx-text-fill:#ffcccc; -fx-font-size:11px;"/>
        </VBox>
    </HBox>

    <HBox spacing="0" prefWidth="1280"
          AnchorPane.topAnchor="136" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <VBox prefWidth="270" spacing="0"
              style="-fx-background-color: #111111; -fx-border-color: #1e1e1e; -fx-border-width: 0 1 0 0;">
            <padding><Insets top="20" left="16" right="16" bottom="20"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 14 0;">
                <Label text="⚡" style="-fx-font-size:14px;"/>
                <Label text="FILTROS"
                       style="-fx-text-fill:#9B0F1F; -fx-font-size:13px; -fx-font-weight:bold; -fx-font-family:'Impact Regular';"/>
            </HBox>

            <Label text="Buscar" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-padding:0 0 4 0;"/>
            <TextField fx:id="txtBuscar"
                       promptText="Marca, modelo..."
                       onKeyReleased="#aplicarFiltros"
                       style="-fx-background-color:#1a1a1a; -fx-text-fill:white; -fx-prompt-text-fill:#555;
                              -fx-border-color:#333; -fx-border-radius:6; -fx-background-radius:6;
                              -fx-padding:8 10; -fx-font-size:12px;"
                       prefWidth="238"/>

            <Region prefHeight="14"/>

            <Label text="Tipo de vehículo" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-padding:0 0 4 0;"/>
            <ComboBox fx:id="comboTipo"
                      promptText="Todos"
                      onAction="#aplicarFiltros"
                      prefWidth="238" prefHeight="36"
                      style="-fx-background-color:#1a1a1a; -fx-border-color:#333; -fx-border-radius:6;
                             -fx-background-radius:6;"/>

            <Region prefHeight="10"/>

            <Label text="Precio por día" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-padding:0 0 4 0;"/>
            <ComboBox fx:id="comboPrecio"
                      promptText="Sin límite"
                      onAction="#aplicarFiltros"
                      prefWidth="238" prefHeight="36"
                      style="-fx-background-color:#1a1a1a; -fx-border-color:#333; -fx-border-radius:6;
                             -fx-background-radius:6;"/>

            <Region prefHeight="10"/>

            <Label text="Marca" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-padding:0 0 4 0;"/>
            <ComboBox fx:id="comboMarca"
                      promptText="Todas"
                      onAction="#aplicarFiltros"
                      prefWidth="238" prefHeight="36"
                      style="-fx-background-color:#1a1a1a; -fx-border-color:#333; -fx-border-radius:6;
                             -fx-background-radius:6;"/>

            <Region prefHeight="10"/>

            <Label text="Período de alquiler" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-padding:0 0 4 0;"/>
            <ComboBox fx:id="comboPeriodo"
                      promptText="Cualquier período"
                      onAction="#aplicarFiltros"
                      prefWidth="238" prefHeight="36"
                      style="-fx-background-color:#1a1a1a; -fx-border-color:#333; -fx-border-radius:6;
                             -fx-background-radius:6;"/>

            <Region prefHeight="10"/>

            <Label text="Autonomía mínima" style="-fx-text-fill:#888; -fx-font-size:11px; -fx-padding:0 0 4 0;"/>
            <ComboBox fx:id="comboAutonomia"
                      promptText="Sin filtro"
                      onAction="#aplicarFiltros"
                      prefWidth="238" prefHeight="36"
                      style="-fx-background-color:#1a1a1a; -fx-border-color:#333; -fx-border-radius:6;
                             -fx-background-radius:6;"/>

            <Region prefHeight="20"/>

            <Button text="↺  Limpiar filtros"
                    onAction="#limpiarFiltros"
                    prefWidth="238" prefHeight="36"
                    style="-fx-background-color:transparent; -fx-text-fill:#9B0F1F;
                           -fx-border-color:#9B0F1F; -fx-border-radius:6; -fx-background-radius:6;
                           -fx-font-size:12px; -fx-cursor:hand;"/>

            <Region prefHeight="20"/>

            <Label fx:id="lblResultados" text="Mostrando 0 vehículos"
                   style="-fx-text-fill:#555; -fx-font-size:11px;"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="0"
              style="-fx-background-color:#0A0A0A;">

            <HBox prefHeight="44" alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color:#111111; -fx-border-color:#1e1e1e; -fx-border-width:0 0 1 0;">
                <padding><Insets left="20" right="20"/></padding>
                <Label text="Ordenar por:"
                       style="-fx-text-fill:#888; -fx-font-size:12px;"/>
                <ComboBox fx:id="comboOrdenar"
                          promptText="Relevancia"
                          onAction="#aplicarFiltros"
                          prefHeight="30"
                          style="-fx-background-color:#1a1a1a; -fx-border-color:#333;
                                 -fx-border-radius:4; -fx-background-radius:4; -fx-font-size:12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⟳ Recargar"
                        onAction="#cargarVehiculos"
                        style="-fx-background-color:transparent; -fx-text-fill:#555;
                               -fx-border-color:#333; -fx-border-radius:4; -fx-background-radius:4;
                               -fx-font-size:11px; -fx-cursor:hand; -fx-padding:4 10;"/>
            </HBox>

            <ScrollPane HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
                        fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color:transparent; -fx-border-color:transparent;">
                <FlowPane fx:id="flowVehiculos"
                          hgap="18" vgap="18"
                          style="-fx-background-color:#0A0A0A; -fx-padding:20;">
                    <VBox fx:id="panelVacio"
                          prefWidth="910" prefHeight="400"
                          alignment="CENTER" spacing="14"
                          style="-fx-background-color:transparent;">
                        <Label text="🔑" style="-fx-font-size:48px;"/>
                        <Label text="No hay vehículos disponibles para alquilar"
                               style="-fx-text-fill:#555; -fx-font-size:18px; -fx-font-weight:bold;"/>
                        <Label text="Agrega vehículos desde el panel de empleado"
                               style="-fx-text-fill:#333; -fx-font-size:13px;"/>
                    </VBox>
                </FlowPane>
            </ScrollPane>
        </VBox>
    </HBox>

</AnchorPane>