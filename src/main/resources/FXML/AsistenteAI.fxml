<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #0a0a0a;" stylesheets="@../css/Asistente.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.ControladorAsistenteAI">

    <!-- ── TOP: navbar + header del asistente ─────────────────────────────── -->
    <top>
        <VBox>

            <!-- Navbar -->
            <HBox fx:id="navbar" alignment="CENTER_LEFT" prefHeight="64.0" prefWidth="1280.0" spacing="0" style="-fx-background-color: #111111; -fx-border-color: transparent transparent #2e2e2e transparent; -fx-border-width: 0 0 1 0;">

                <Pane prefHeight="64" prefWidth="220" style="-fx-background-color: transparent;">
                    <ImageView fitHeight="91.0" fitWidth="160.0" layoutX="41.0" layoutY="-14.0" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@../Imagenes/logoprovisional.png" /></image>
                    </ImageView>
                </Pane>

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="boton_inicio" mnemonicParsing="false" onAction="#cambiarInicio" styleClass="boton-nav" text="INICIO">
               <stylesheets>
                  <URL value="@../css/styles.css" />
                  <URL value="@../css/styles.css" />
               </stylesheets></Button>
                <Button fx:id="boton_comprar" mnemonicParsing="false" onAction="#cambiarCompras" styleClass="boton-nav" stylesheets="@../css/styles.css" text="COMPRAR" />
                <Button fx:id="boton_alquilar" mnemonicParsing="false" styleClass="boton-nav" stylesheets="@../css/styles.css" text="ALQUILAR" />
                <Button fx:id="boton_contratos" mnemonicParsing="false" styleClass="boton-nav" stylesheets="@../css/styles.css" text="CONTRATOS" />
                <Button fx:id="boton_flota" mnemonicParsing="false" styleClass="boton-nav" stylesheets="@../css/styles.css" text="FLOTA" />
                <Button fx:id="boton_asistente" mnemonicParsing="false" styleClass="boton-nav" stylesheets="@../css/styles.css" text="ASISTENTE" />

                <Region prefWidth="16" />

                <Button fx:id="boton_cerrar_sesion" mnemonicParsing="false" prefHeight="36" prefWidth="150" style="-fx-background-color: #1a0808; -fx-text-fill: #cc3333; -fx-font-family: 'Impact Regular'; -fx-font-size: 13px; -fx-background-radius: 6; -fx-border-color: #4a1010; -fx-border-radius: 6; -fx-border-width: 1; -fx-cursor: hand;" text="⏻  CERRAR SESIÓN" />
                <Pane prefWidth="16" />
            </HBox>

            <!-- Header del asistente -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header">
                <padding><Insets bottom="16" left="20" right="20" top="16" /></padding>
                <VBox>
                    <Label styleClass="header-titulo" text="Asistente Virtual Akira" />
                    <Label styleClass="header-subtitulo" text="Tu guía de vehículos eléctricos" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnLimpiar" onAction="#limpiarChat" styleClass="btn-limpiar" text="↺ Nuevo chat" />
            </HBox>

        </VBox>
    </top>

    <!-- ── CENTRO: preguntas rápidas + chat ───────────────────────────────── -->
    <center>
        <VBox>
            <HBox alignment="CENTER" spacing="8" styleClass="preguntas-rapidas">
                <padding><Insets bottom="12" left="16" right="16" top="12" /></padding>
                <Button fx:id="btnQ1" styleClass="btn-pregunta" text="¿Cuál es el vehículo más económico?" />
                <Button fx:id="btnQ2" styleClass="btn-pregunta" text="Recomiéndame un auto familiar" />
                <Button fx:id="btnQ3" styleClass="btn-pregunta" text="¿Cuál es el vehículo con mayor autonomía?" />
                <Button fx:id="btnQ4" styleClass="btn-pregunta" text="¿Alquilar o comprar?" />
                <Button fx:id="btnQ5" styleClass="btn-pregunta" text="¿Patineta o bicicleta?" />
                <Button fx:id="btnQ6" styleClass="btn-pregunta" text="¿Cuáles son las ventajas de un vehículo eléctrico?" />
            </HBox>

            <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-chat" VBox.vgrow="ALWAYS">
                <VBox fx:id="chatContainer" spacing="6" styleClass="chat-container">
                    <padding><Insets bottom="16" left="8" right="8" top="16" /></padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

    <!-- ── BOTTOM: campo de texto ─────────────────────────────────────────── -->
    <bottom>
        <HBox alignment="CENTER" spacing="10" styleClass="input-bar">
            <padding><Insets bottom="14" left="16" right="16" top="14" /></padding>
            <TextField fx:id="campoTexto" onAction="#enviarMensaje" promptText="Escribe tu pregunta sobre vehículos eléctricos..." styleClass="campo-texto" HBox.hgrow="ALWAYS" />
            <ProgressIndicator fx:id="indicadorCarga" prefHeight="24" prefWidth="24" styleClass="indicador-carga" />
            <Button fx:id="btnEnviar" onAction="#enviarMensaje" styleClass="btn-enviar" text="Enviar ➤" />
        </HBox>
    </bottom>

</BorderPane>
